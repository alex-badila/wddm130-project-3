<%- include("layouts/header"); -%>
<%- include("layouts/nav"); -%>

<main>
    <% if(typeof(webdata) !== "undefined" && webdata) { %>
        <h1><%- webdata.name -%></h1>
        <% if(webdata.image) { %>
            <img src="<%= webdata.image %>" alt="Page Image" />
        <% } %>
        <%- webdata.content -%>
    <% } %>
</main>

<%- include("layouts/footer"); -%>