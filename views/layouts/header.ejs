<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CMS Website</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/tinymce/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
    <script>
      tinymce.init({
        selector: '.mytextarea',
        license_key: 'gpl' // gpl for open source, T8LK:... for commercial
      });
    </script>
</head>
<body>
    <header>
        <% if (typeof(loggedIn) !== "undefined" && loggedIn) {%>
            <a href="/logout">Logout? <%=logName%></a>
        <%} else {%>
            <a href="/login">Login</a>
        <%}%>
        <div class="headerContent">
            <img src="/images/alex-badila-logo.jpg" alt="Logo" class="logo" />
            <h1>CMS Website</h1>
        </div>
    </header>
